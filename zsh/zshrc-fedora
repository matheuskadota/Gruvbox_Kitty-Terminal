# --- Oh My Zsh ---
export ZSH="$HOME/.oh-my-zsh"

# Desativa tema do Oh My Zsh (Starship cuida do prompt)
ZSH_THEME=""

# Plugins
plugins=(
git
zsh-autosuggestions
zsh-syntax-highlighting
)

# Carrega Oh My Zsh
source $ZSH/oh-my-zsh.sh

# --- Idioma e Editor ---
export LANG=en_US.UTF-8
export EDITOR="nvim"

# --- Configurações de Interface ---

# Inicializa o Starship (Motor do design das pílulas)
eval "$(starship init zsh)"

# Limpa a tela e executa o Fastfetch APENAS UMA VEZ ao abrir
clear
fastfetch

# --- Histórico e Comportamento ---
HISTSIZE=10000
SAVEHIST=10000
setopt APPEND_HISTORY
setopt SHARE_HISTORY

# --- Atalhos (Aliases) ---
alias c='clear'
alias v='code'
alias ..='cd ..'
alias gs='git status'
